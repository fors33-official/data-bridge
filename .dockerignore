# Prevent leaking secrets / internal material into Docker build context.
# Keep context small and deterministic for CI and local builds.

# Local packaging staging (never part of image context)
/products/

# Rust build artifacts
/target/

# Local outputs (never ship)
/out/

# Local scratch tests and experiments (never ship)
.tmp-tests/

# Internal-only reference material (never ship)
/reference/

# Internal documentation (entire folder is maintainer-only)
/docs/

# Root config examples are mounted at runtime, not copied into the runtime image layers.
# `config/templates/` must stay in the build context: `include_str!` in src/commands/generate.rs.
config/*
!config/templates/
!config/templates/**

# Secrets / credentials
.env
**/env
**/*.ini
**/*.pem
**/*.key
**/.ssh/

# Repo metadata / editor artifacts
/.git/
/.gitignore
/.gitattributes
/.github/
/.cursor/
.cursorignore
/.vscode/

# OS / misc
.DS_Store
Thumbs.db
*.log

# Python/Node leftovers (if present)
**/__pycache__/
**/*.pyc
**/node_modules/
**/.venv/
**/.pytest_cache/

